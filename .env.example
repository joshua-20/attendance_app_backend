# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no extra setup required)
DATABASE_URL=sqlite:///./attendance.db

# PostgreSQL example (uncomment and fill in for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/attendance_db

# ── Upload storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Cloudinary (set all three to enable; omit to use local disk) ─────────────
# Sign up free at https://cloudinary.com — 25 GB free storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Face Recognition ──────────────────────────────────────────────────────────
# Cosine similarity threshold for SFace matching (0.363 = OpenCV recommended)
FACE_COSINE_THRESHOLD=0.363

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the mobile / web frontend
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8081

# ── Server (used by run.py) ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Set to false in production (Railway sets PORT automatically)
RELOAD=true
